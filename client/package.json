{
  "name": "springreact-runtime",
  "version": "0.1.0",
  "private": true,
  "description": "Internal: the React runtime that SpringReact bundles into its jar and serves automatically. Consumers never install this.",
  "type": "module",
  "scripts": {
    "build": "esbuild src/bootstrap.tsx --bundle --format=iife --minify --jsx=automatic --target=es2020 --outfile=dist/springreact.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "esbuild": "^0.24.2",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
